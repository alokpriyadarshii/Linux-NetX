# Linux-Net Environment Configuration
# Copy this file to .env and update the values

# ==========================================
# Core Authentication
# ==========================================

# Redis Password (Required)
# Used for secure communication between Controller and Workers
LINUX_NET_REDIS__PASSWORD=change_this_redis_password

# API Key (Required) 
# Used to authenticate all REST API requests
LINUX_NET_SERVER__API_KEY=change_this_api_key

# ==========================================
# Server Settings
# ==========================================

# Optional: External URL for downloads (e.g., http://your-ip:9000)
# Used for constructing file download links in API responses
# LINUX_NET_SERVER__EXTERNAL_URL=http://localhost:9000

# Optional: Time Zone (e.g., Asia/Shanghai, UTC, America/New_York)
# Controls the timestamp formatting in API responses and logs
TZ=Asia/Shanghai

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR)
LINUX_NET_LOG__LEVEL=INFO

# ==========================================
# Credential Management (Vault)
# ==========================================

# Optional: Credential Provider (set enabled=true to use Vault)
LINUX_NET_CREDENTIAL__ENABLED=false
LINUX_NET_CREDENTIAL__NAME=vault_kv

# Optional: Vault KV v2 settings (token OR AppRole)
LINUX_NET_CREDENTIAL__ADDR=http://vault:8200
LINUX_NET_CREDENTIAL__ALLOWED_PATHS=kv/linux_net
LINUX_NET_CREDENTIAL__VERIFY=false
LINUX_NET_CREDENTIAL__CACHE_TTL=30

# Use one of the following auth methods
# A: Token-based authentication
# LINUX_NET_VAULT_TOKEN=dev-root-token

# B: AppRole-based authentication
# LINUX_NET_VAULT_ROLE_ID=
# LINUX_NET_VAULT_SECRET_ID=

# ==========================================
# Audit & Compliance (MongoDB)
# ==========================================

# Optional: MongoDB Audit Settings
# If enabled, all job results and detached task lifecycles will be 
# asynchronously persisted to MongoDB for long-term audit trail.
LINUX_NET_MONGODB__ENABLED=false
LINUX_NET_MONGODB__URI=mongodb://localhost:27017
LINUX_NET_MONGODB__DATABASE=linux_net
LINUX_NET_MONGODB__COLLECTION=audit_jobs
LINUX_NET_MONGODB__DETACHED_COLLECTION=audit_detached_tasks
LINUX_NET_MONGODB__RETENTION_DAYS=30
LINUX_NET_MONGODB__DETACHED_RETENTION_DAYS=30
LINUX_NET_MONGODB__MAX_DOCUMENTS=1000000
